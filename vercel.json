{
  "redirects": [
    {
      "source": "/Ads.txt",
      "destination": "/ads.txt",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "gamevault-umber.vercel.app"
        }
      ],
      "destination": "https://www.yoplayables.com/:path*",
      "permanent": true
    }
  ]
}
